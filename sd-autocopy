#!/bin/bash
#
# sd-autocopy - Copies/Moves images automatically from inserted media
# Root script: handles mount, UUID check, then hands off to user script.

USER=koom
HANDLED_LABELS="EOS_DIGITAL,EOS2"
MOUNT_BASE=/mnt/sd-autocopy
SCRIPT_DIR="$(dirname "$0")"

# END OF CONFIGURATION ########################################################

if [ -z "$DEVNAME" ]; then
    exit 1
fi

# Probe filesystem label directly since udev env vars aren't available yet.
# Labels survive camera reformats; filesystem UUIDs do not.
ID_FS_LABEL=$(blkid -s LABEL -o value "$DEVNAME")

logger -t sd-autocopy "Starting sd-autocopy for device $DEVNAME (LABEL=$ID_FS_LABEL)"

if [ -z "$ID_FS_LABEL" ]; then
    logger -t sd-autocopy "Could not determine LABEL for $DEVNAME, skipping"
    exit 1
fi

shopt -s nocasematch
if [[ ",$HANDLED_LABELS," != *",${ID_FS_LABEL},"* ]]; then
    logger -t sd-autocopy "Got unhandled LABEL, skipping (LABEL: $ID_FS_LABEL)"
    exit 1
fi
shopt -u nocasematch

logger -t sd-autocopy "Got handled LABEL ($ID_FS_LABEL), mounting..."

MOUNT="$MOUNT_BASE/$(date -u +%Y%m%d_%H%M%S)"
mkdir -p "$MOUNT"

USER_ID=$(id -u $USER)
GROUP_ID=$(id -g $USER)
mount -o uid=$USER_ID,gid=$GROUP_ID $DEVNAME "$MOUNT"

su - $USER -s /bin/bash -- "$SCRIPT_DIR/sd-autocopy-copy" "$MOUNT"
