#!/bin/bash
#
# sd-autocopy - Copies/Moves images automatically from inserted media
# Root script: handles mount, UUID check, then hands off to user script.

USER=koom
HANDLED_UUIDS="2C32-CEEB"
MOUNT_BASE=/mnt/sd-autocopy
SCRIPT_DIR="$(dirname "$0")"

# END OF CONFIGURATION ########################################################

if [ -z "$DEVNAME" ]; then
    exit 1
fi

# Probe filesystem UUID directly since udev env vars aren't available yet
ID_FS_UUID=$(blkid -s UUID -o value "$DEVNAME")

logger -t sd-autocopy "Starting sd-autocopy for device $DEVNAME (UUID=$ID_FS_UUID)"

if [ -z "$ID_FS_UUID" ]; then
    logger -t sd-autocopy "Could not determine UUID for $DEVNAME, skipping"
    exit 1
fi

if ! echo "$HANDLED_UUIDS" | grep -i "$ID_FS_UUID" >/dev/null 2>&1; then
    logger -t sd-autocopy "Got unhandled UUID, skipping (UUID: $ID_FS_UUID)"
    exit 1
fi

logger -t sd-autocopy "Got handled UUID ($ID_FS_UUID), mounting..."

MOUNT="$MOUNT_BASE/$(date -u +%Y%m%d_%H%M%S)"
mkdir -p "$MOUNT"

USER_ID=$(id -u $USER)
GROUP_ID=$(id -g $USER)
mount -o uid=$USER_ID,gid=$GROUP_ID $DEVNAME "$MOUNT"

su - $USER -s /bin/bash -- "$SCRIPT_DIR/sd-autocopy-copy" "$MOUNT"
